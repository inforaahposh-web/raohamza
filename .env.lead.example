# Lead notifications (optional — add in Vercel → Environment Variables)

# WhatsApp to YOU via CallMeBot (free). Setup:
# 1. Add +34 644 66 56 05 on WhatsApp and send: "I allow callmebot to send me messages"
# 2. Bot replies with your apikey
# 3. Put that apikey here. Phone is taken from Admin → Site info → WhatsApp
CALLMEBOT_APIKEY=

# Email to YOU via Resend (https://resend.com)
RESEND_API_KEY=
LEAD_FROM_EMAIL=onboarding@resend.dev

# Optional override if site settings email/whatsapp empty
LEAD_NOTIFY_EMAIL=
LEAD_NOTIFY_WHATSAPP=
